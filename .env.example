# NIBS Office Administrator Pathway Portal — environment example
# Copy to .env (local) or office-admin-portal.env (Portainer stack) and fill in real values.
# NEVER commit real secrets.

# ===== Environment =====
APP_ENV=uat                                  # development | uat | production
APP_URL=https://uat-office.naleli.co.za
APP_PORT=8088                                # internal container port (also accepts PORT)

# ===== Database =====
# MVP uses SQLite. Leave DATABASE_URL blank for the default /data/nibs.db.
# To use Postgres later: DATABASE_URL=postgres://user:pw@host:5432/db
DATABASE_URL=
SQLITE_PATH=/data/nibs.db
DB_PATH=/data/nibs.db

# ===== Auth secrets (rotate before production) =====
JWT_SECRET=replace-me-with-32+chars-random-string
SESSION_SECRET=replace-me-with-another-32+chars-random-string

# ===== File storage =====
UPLOAD_DIR=/data/uploads
PDF_EXPORT_DIR=/data/uploads/exports

# ===== Admin (first-run) =====
ADMIN_EMAIL=admin@naleli.co.za
# Set ADMIN_DEFAULT_PASSWORD for UAT. The portal forces a password change on first
# login if this is left at "change-on-first-login".
ADMIN_DEFAULT_PASSWORD=change-on-first-login
# Legacy alias (kept for backwards compat)
ADMIN_PASSWORD=

# ===== Email (SMTP, optional in MVP) =====
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="NIBS Pathway Portal <no-reply@naleli.co.za>"

# ===== Payments (PayFast/Paystack/Yoco — wire in later) =====
PAYMENT_PROVIDER=manual
PAYMENT_MERCHANT_ID=
PAYMENT_MERCHANT_KEY=
