# NIBS Office Administrator Pathway Portal — environment example
# Copy to .env (local) or office-admin-portal.env (Portainer) and fill in real values.
# NEVER commit real secrets.

NODE_ENV=production

# ===== Network =====
APP_PORT=8088
PORT=8088
APP_URL=https://uat-office.naleli.co.za

# ===== Database =====
# SQLite (MVP). For Postgres, set DATABASE_URL=postgres://user:pw@host:5432/db
# and the app will auto-detect.
DATABASE_URL=
SQLITE_PATH=/data/nibs.db
DB_PATH=/data/nibs.db

# ===== Auth secrets (rotate before production) =====
JWT_SECRET=replace-me-with-32+chars-random-string
SESSION_SECRET=replace-me-with-another-32+chars-random-string

# ===== File storage =====
UPLOAD_DIR=/data/uploads
PDF_EXPORT_DIR=/data/uploads/exports

# ===== Admin (first-run) =====
ADMIN_EMAIL=admin@naleli.co.za
ADMIN_PASSWORD=ChangeMe123!

# ===== Email (SMTP, optional in MVP) =====
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="NIBS Pathway Portal <no-reply@naleli.co.za>"

# ===== Payments (PayFast/Paystack/Yoco — wire in later) =====
PAYMENT_PROVIDER=manual
PAYMENT_MERCHANT_ID=
PAYMENT_MERCHANT_KEY=
